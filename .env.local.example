# ──────────────────────────────────────────────
# SUPABASE  (get from: supabase.com → your project → Settings → API)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ──────────────────────────────────────────────
# STRIPE  (get from: dashboard.stripe.com → Developers → API keys)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────
# RESEND  (get from: resend.com → API Keys)
# ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://skillbridge.app
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=15
